<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema principal de la app -->
    <style name="Theme.MiAplicacion" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Tema específico para el Splash Screen (idéntico al de values) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Fondo blanco -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- Usamos ic_splash_logo que tiene el tamaño forzado a 80dp -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <!-- Tema al que cambiará la app después del Splash -->
        <item name="postSplashScreenTheme">@style/Theme.MiAplicacion</item>
    </style>
</resources>
